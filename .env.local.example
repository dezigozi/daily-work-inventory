# Google Gemini API キー（週次レポートの総評生成に使用。サーバー側のみ）
# https://aistudio.google.com/apikey で無料発行できる（クレカ不要・無料枠で十分動く）
GEMINI_API_KEY=AIza...

# 使うモデルを変えたい時だけ指定（省略時は gemini-2.5-flash-lite ＝無料枠が最大）
# GEMINI_MODEL=gemini-2.5-flash

# Upstash Redis（Vercel KV）— 本番のデータ永続化に使用
# Vercel Marketplace から Upstash を接続すると自動で環境変数が入る。
# ローカルでは未設定でもOK（.data/ 配下のファイルに保存するfallbackが動く）。
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
